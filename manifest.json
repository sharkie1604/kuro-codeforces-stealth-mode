{
  "manifest_version": 3,
  
  "name": "Kuro",
  "version": "1.0",
  "description": "The ultimate Codeforces stealth tool. Hide tags, ratings, and distractions.",

  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://codeforces.com/*"],
      "js": ["content.js"]
    }
  ]
}